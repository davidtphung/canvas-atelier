{
  "name": "canvas-atelier",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_BASE=/ vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "VITE_BASE=/canvas-atelier/ tsc --noEmit && VITE_BASE=/canvas-atelier/ vite build",
    "deploy": "npm run build:pages && touch dist/.nojekyll && npx gh-pages -d dist -m 'Deploy Canvas Atelier production build'",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "mediabunny": "^1.50.8",
    "nanoid": "^5.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
